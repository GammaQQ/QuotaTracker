{
	"name": "quotatracker",
	"type": "module",
	"version": "0.1.0",
	"description": "Unified quota tracker — core CLI that outputs JSON for SwiftUI/Tauri UIs",
	"bin": {
		"quotatracker": "./src/index.ts"
	},
	"main": "./dist/index.js",
	"scripts": {
		"start": "bun ./src/index.ts",
		"build": "tsdown",
		"test": "vitest run",
		"typecheck": "tsc --noEmit"
	},
	"devDependencies": {
		"@types/bun": "^1.2.0",
		"tsdown": "^0.12.0",
		"typescript": "^5.8.0",
		"valibot": "^1.1.0",
		"vitest": "^3.2.0",
		"tinyglobby": "^0.2.0",
		"es-toolkit": "^1.34.0",
		"picocolors": "^1.1.0"
	},
	"engines": {
		"node": ">=20.0.0"
	}
}
