		"typescript": "^5.8.0",
		"valibot": "^1.1.0",
		"vitest": "^3.2.0",
		"tinyglobby": "^0.2.0",
		"es-toolkit": "^1.34.0",
		"picocolors": "^1.1.0"
	},
	"engines": {
		"node": ">=20.0.0"
	}
