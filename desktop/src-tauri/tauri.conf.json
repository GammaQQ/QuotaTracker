{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "QuotaTracker",
  "version": "0.1.0",
  "identifier": "com.quotatracker.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "QuotaTracker",
        "width": 420,
        "height": 660,
        "minWidth": 360,
        "minHeight": 500,
        "resizable": true,
        "visible": false,
        "skipTaskbar": true,
        "decorations": true,
        "alwaysOnTop": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/gammaqq/quotatracker/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDVDRDYzMkFDQjY2QzE1MzIKUldReUZXeTJyRExXWERmQ0xjb0M2amQwRWthWTgyVEIzSm15WXVzZ1c2Zys5ZGFhcVc0em5KK1kK"
    }
  }
}
